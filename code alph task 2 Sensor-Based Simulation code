from machine import Pin, ADC
import time

# Pins setup
ldr = ADC(Pin(26))      # GP26 analog input for LDR
led = Pin(15, Pin.OUT)  # GP15 digital output for LED

threshold = 15000      # Light sensitivity threshold

while True:
    ldr_value = ldr.read_u16() # Reads value from 0 to 65535
    print("LDR Value:", ldr_value)
    
    # Check if it is dark (Wokwi Pico LDR gives higher value in dark)
    if ldr_value > threshold:  
        led.value(1)           # LED ON
    else:
        led.value(0)           # LED OFF
        
    time.sleep(0.5)
